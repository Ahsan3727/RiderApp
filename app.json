{
  "expo": {
    "name": "GrocerEase Rider",
    "slug": "RiderApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "sdkVersion": "54.0.0",
    "platforms": [
      "android"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Groxo to access your location even when the app is closed.",
          "locationAlwaysPermission": "Allow Groxo to access your location in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ]
    ],
    "android": {
      "package": "com.grocerase.rider",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "dc7827de-6d9f-41e2-b206-0ea1147a5121"
      }
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/dc7827de-6d9f-41e2-b206-0ea1147a5121"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {}
  }
}
